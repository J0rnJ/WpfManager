<Application x:Class="TaskManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:TaskManager.Converters"
             xmlns:taskItemViewModels="clr-namespace:TaskManager.ViewModels.TaskItem"
             xmlns:taskItemViews="clr-namespace:TaskManager.Views.TaskItem">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Styles -->
                <ResourceDictionary Source="/Resources/Colors.xaml" />
                <ResourceDictionary Source="/Resources/Brushes.xaml" />
                <ResourceDictionary Source="/Resources/Styles.xaml" />
                
                <!-- Converters -->
                <ResourceDictionary>
                    <converters:BooleanToCompletedTextConverter x:Key="BooleanToCompletedTextConverter" />
                    <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
                    <converters:CompletedToColorConverter x:Key="CompletedToColorConverter" />
                    <converters:CompletedToIconConverter x:Key="CompletedToIconConverter" />
                </ResourceDictionary>
                
                <!-- Popup View Templates-->
                <ResourceDictionary>
                    <DataTemplate DataType="{x:Type taskItemViewModels:TaskItemCreateViewModel}">
                        <taskItemViews:TaskItemCreateView />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type taskItemViewModels:TaskItemEditViewModel}">
                        <taskItemViews:TaskItemEditView />
                    </DataTemplate>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
