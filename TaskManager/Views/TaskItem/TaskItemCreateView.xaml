<UserControl x:Class="TaskManager.Views.TaskItem.TaskItemCreateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Title -->
        <TextBlock Text="Create Task" Style="{StaticResource HeaderTextStyle}" />
        
        <!-- Input Fields -->
        <StackPanel Grid.Row="1" Margin="0 0 0 20">
            <TextBlock Text="Title" Style="{StaticResource TitleTextStyle}"/>
            <TextBox Text="{Binding Title}" Style="{StaticResource PopupTextBoxStyle}"
                     HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                     TextWrapping="NoWrap"/>

            <TextBlock Text="Description" Style="{StaticResource TitleTextStyle}" />
            <TextBox Text="{Binding Description}" Style="{StaticResource PopupTextBoxStyle}"
                     AcceptsReturn="True" Height="80" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"/>
        </StackPanel>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource PopupButtonStyle}"
                    Command="{Binding CancelCommand}" />

            <Button Content="Save" Style="{StaticResource PopupButtonStyle}"
                    Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
