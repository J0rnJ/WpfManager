<UserControl x:Class="TaskManager.Views.Shared.PopupHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Visibility="{Binding IsPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}">

        <!-- Frosted overlay -->
        <Grid Background="{StaticResource Brush.PopupOverlayBackground}" Style="{StaticResource PopupOverlayBlur}" />

        <Border Style="{StaticResource PopupContainerStyle}">
            <ContentControl Content="{Binding PopupViewModel}" />
        </Border>
    </Grid>
</UserControl>
