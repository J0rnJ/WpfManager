<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="Brush.BackgroundDark" Color="{StaticResource Color.BackgroundDark}" />
    <SolidColorBrush x:Key="Brush.PanelDark" Color="{StaticResource Color.PanelDark}" />
    <SolidColorBrush x:Key="Brush.PanelDarker" Color="{StaticResource Color.PanelDarker}" />
    <SolidColorBrush x:Key="Brush.PopupBackground" Color="{StaticResource Color.BackgroundPopup}" />
    <SolidColorBrush x:Key="Brush.PopupOverlayBackground" Color="{StaticResource Color.BackgroundFrosted}" />
    <Style x:Key="PopupOverlayBlur" TargetType="Grid">
        <Setter Property="Effect">
            <Setter.Value>
                <BlurEffect Radius="12" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Accents -->
    <SolidColorBrush x:Key="Brush.AccentBlue" Color="{StaticResource Color.AccentBlue}" />
    <SolidColorBrush x:Key="Brush.AccentGreen" Color="{StaticResource Color.AccentGreen}" />

    <!-- Text -->
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />

</ResourceDictionary>